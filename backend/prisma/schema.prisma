generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int        @id @default(autoincrement())
  username     String     @unique
  passwordHash String
  createdAt    DateTime   @default(now())
  contracts    Contract[]
  ships        Ship[]
}

model Ship {
  id            Int            @id @default(autoincrement())
  name          String
  model         String         @default("")
  pilot         String         @default("")
  scu           Int
  userId        Int?
  user          User?          @relation(fields: [userId], references: [id])
  contractLinks ContractShip[]
}

model Contract {
  id        Int            @id @default(autoincrement())
  userId    Int
  name      String         @default("UNTITLED CONTRACT")
  client    String         @default("")
  status    String         @default("PENDING")
  payout    Int            @default(0)
  createdAt DateTime       @default(now())
  user      User           @relation(fields: [userId], references: [id])
  stops     ContractStop[]
  ships     ContractShip[]
}

model ContractStop {
  id         Int        @id @default(autoincrement())
  contractId Int
  type       String
  station    String     @default("")
  position   Int
  contract   Contract   @relation(fields: [contractId], references: [id], onDelete: Cascade)
  items      StopItem[]
}

model StopItem {
  id       Int          @id @default(autoincrement())
  stopId   Int
  material String       @default("")
  qty      Int          @default(0)
  done     Boolean      @default(false)
  stop     ContractStop @relation(fields: [stopId], references: [id], onDelete: Cascade)
}

model ContractShip {
  contractId Int
  shipId     Int
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  ship       Ship     @relation(fields: [shipId], references: [id], onDelete: Cascade)

  @@id([contractId, shipId])
}

